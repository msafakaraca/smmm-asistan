{
  "name": "smmm-asistan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/cleanup-prisma.js",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node --project tsconfig.server.json server.ts",
    "dev:next": "node scripts/cleanup-prisma.js && cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:turbo": "node scripts/cleanup-prisma.js && cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node --project tsconfig.server.json server.ts --turbo",
    "dev:all": "npx concurrently -k -n \"SERVER,BUILD,APP\" -c \"blue,magenta,yellow\" \"npm run dev\" \"cd electron-bot && npm run dev\" \"npx wait-on http://localhost:3000 http://localhost:5173 && cd electron-bot && npm start\"",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "cross-env NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "start:next": "cross-env NODE_ENV=production next start",
    "type-check": "tsc --noEmit --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "clean": "node scripts/cleanup-prisma.js && rd /s /q .next node_modules\\.cache 2>nul || echo Cache cleaned",
    "clean:prisma": "node scripts/cleanup-prisma.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
