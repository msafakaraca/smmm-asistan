  expiresAt    DateTime?
  activatedAt  DateTime?
  tenantId     String    @unique @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenants      tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([status])
