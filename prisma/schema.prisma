  turzMeta   Json?
  konk       String   @default("bos")
  konkMeta   Json?
  poset      String   @default("bos")
  posetMeta  Json?
  kdv2       String   @default("bos")
  kdv2Meta   Json?
  kdv9015    String   @default("bos")
