model gecici_vergi_kontrol {
  id                    String    @id @default(uuid()) @db.Uuid
  customerId            String    @db.Uuid
  year                  Int
  month                 Int       // Çeyreğin son ayı (3, 6, 9, 12)

  vergiTuru             String    // "GGECICI" veya "KGECICI"
  vergilendirmeDonemi   String?   // "10/2025-12/2025"

  matrah                Decimal?  @db.Decimal(15, 2)
  tahakkukEden          Decimal?  @db.Decimal(15, 2)
  mahsupEdilen          Decimal?  @db.Decimal(15, 2)
  odenecek              Decimal?  @db.Decimal(15, 2)
  damgaVergisi1047      Decimal?  @db.Decimal(15, 2)
  damgaVergisi1048      Decimal?  @db.Decimal(15, 2)
  vade                  DateTime?
  beyanTarihi           DateTime?

  tahakkukDocumentId    String?

  status                String    @default("bekliyor")
  notes                 String?

  tenantId              String    @db.Uuid
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  customers             customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants               tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([customerId, year, month, vergiTuru])
  @@index([tenantId])
  @@index([tenantId, year, month])
  @@index([customerId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model email_messages {
  id                      String                  @id @default(uuid()) @db.Uuid
  provider                String?
  providerId              String?
  threadId                String?
  fromEmail               String?
  fromName                String?
  toEmails                String[]                @default([])
  ccEmails                String[]                @default([])
  subject                 String?
  snippet                 String?
  bodyHtml                String?
  bodyText                String?
  isRead                  Boolean                 @default(false)
  isStarred               Boolean                 @default(false)
  labelIds                String[]                @default([])
  folder                  String?
  hasAttachments          Boolean                 @default(false)
  attachments             Json?
  receivedAt              DateTime?
  connectionId            String                  @db.Uuid
  tenantId                String                  @db.Uuid
  customerId              String?                 @db.Uuid
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  bcc                     String[]                @default([])
  cc                      String[]                @default([])
  from                    String?
  headers                 Json?
  messageId               String
  to                      String[]                @default([])
  email_oauth_connections email_oauth_connections @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  customers               customers?              @relation(fields: [customerId], references: [id])
  tenants                 tenants                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([connectionId, messageId])
  @@unique([connectionId, providerId])
  @@index([connectionId])
  @@index([customerId])
  @@index([folder])
  @@index([isRead])
  @@index([receivedAt])
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model email_oauth_connections {
  id             String           @id @default(uuid()) @db.Uuid
  provider       String
  email          String
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  scopes         String[]         @default([])
  lastSyncAt     DateTime?
  syncStatus     String           @default("idle")
  syncError      String?
  tenantId       String           @db.Uuid
  userId         String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isActive       Boolean          @default(true)
  scope          String?
  tokenExpiry    DateTime?
  email_messages email_messages[]
  tenants        tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, provider, email])
  @@index([provider])
  @@index([syncStatus])
  @@index([tenantId])
}

model jobs {
  id            String        @id @default(uuid()) @db.Uuid
  type          String
  status        String        @default("PENDING")
  payload       Json
  result        Json?
  error         String?
  tenantId      String        @db.Uuid
  userId        String        @db.Uuid
  createdAt     DateTime      @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  tenants       tenants       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user_profiles user_profiles @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

