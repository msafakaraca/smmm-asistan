generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model announcement_logs {
  id                      String                   @id @default(uuid()) @db.Uuid
  channel                 String
  status                  String                   @default("pending")
  recipientEmail          String?
  recipientPhone          String?
  recipientName           String?
  subject                 String?
  content                 String?
  sentAt                  DateTime?
  error                   String?
  customerId              String?                  @db.Uuid
  announcementId          String?                  @db.Uuid
  tenantId                String                   @db.Uuid
  createdAt               DateTime                 @default(now())
  scheduled_announcements scheduled_announcements? @relation(fields: [announcementId], references: [id])
  customers               customers?               @relation(fields: [customerId], references: [id])
  tenants                 tenants                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([channel])
  @@index([createdAt])
  @@index([customerId])
  @@index([status])
  @@index([tenantId])
}

model announcement_templates {
  id                      String                    @id @default(uuid()) @db.Uuid
  name                    String
  subject                 String?
  content                 String
  type                    String                    @default("general")
  channels                String[]                  @default([])
  isActive                Boolean                   @default(true)
  tenantId                String                    @db.Uuid
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  tenants                 tenants                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduled_announcements scheduled_announcements[]

  @@unique([tenantId, name])
  @@index([isActive])
  @@index([tenantId])
}

model beyanname_takip {
  id           String    @id @default(uuid()) @db.Uuid
  year         Int
  month        Int
  customerId   String    @db.Uuid
  beyannameler Json      @default("{}")
  tenantId     String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customers    customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants      tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([customerId, year, month])
  @@index([tenantId])
  @@index([year, month])
  @@index([tenantId, year, month])
  @@index([customerId])
}

model beyanname_turleri {
  id        String   @id @default(uuid()) @db.Uuid
  kod       String
  aciklama  String
  kisaAd    String?
  kategori  String?
  aktif     Boolean  @default(true)
  siraNo            Int      @default(0)
  donemSecenekleri  String[] @default([])
  tenantId          String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kod])
  @@index([tenantId])
  @@index([tenantId, aktif])
  @@index([kategori])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bulk_send_logs {
  id             String     @id @default(uuid()) @db.Uuid
  documentId     String?    @db.Uuid
  customerId     String?    @db.Uuid
  mailSent       Boolean    @default(false)
  mailSentAt     DateTime?
  mailSentTo     String?
  mailError      String?
  whatsappSent   Boolean    @default(false)
  whatsappSentAt DateTime?
  whatsappSentTo String?
  whatsappType   String?
  whatsappError  String?
  smsSent        Boolean    @default(false)
  smsSentAt      DateTime?
  smsSentTo      String?
  smsError       String?
  year           Int?
  month          Int?
  beyannameTuru  String?
  dosyaTipi      String?
  sentBy         String?
  tenantId       String     @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  error          String?
  message        String?
  recipientEmail String?
  recipientName  String?
  recipientPhone String?
  sentAt         DateTime?
  status         String     @default("pending")
  subject        String?
  type           String
  documents      documents? @relation(fields: [documentId], references: [id])
  tenants        tenants    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([documentId, tenantId])
  @@index([customerId])
  @@index([documentId])
  @@index([status])
  @@index([tenantId])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customer_group_members {
  id              String          @id @default(uuid()) @db.Uuid
  groupId         String          @db.Uuid
  customerId      String          @db.Uuid
  tenantId        String          @db.Uuid
  addedAt         DateTime        @default(now())
  customers       customers       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customer_groups customer_groups @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tenants         tenants         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([groupId, customerId])
  @@index([customerId])
  @@index([groupId])
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customer_groups {
  id                     String                   @id @default(uuid()) @db.Uuid
  name                   String
  description            String?
  color                  String                   @default("#3B82F6")
  icon                   String?
  sirketTipiFilter       String?
  tenantId               String                   @db.Uuid
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  beyannameTypes         String[]                 @default([])
  customer_group_members customer_group_members[]
  tenants                tenants                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model customers {
  id                       String                   @id @default(uuid()) @db.Uuid
  unvan                    String
  kisaltma                 String?
  vknTckn                  String
  vergiKimlikNo            String?
  tcKimlikNo               String?
  vergiDairesi             String?
  sirketTipi               String                   @default("sahis")
  faaliyetKodu             String?
  sortOrder                Int                      @default(0)
  email                    String?
  telefon1                 String?
  telefon2                 String?
  adres                    String?
  yetkiliKisi              String?
  gibKodu                  String?
  gibSifre                 String?
  gibParola                String?
  interaktifSifre          String?
  emuhurPin                String?
  sgkKullaniciAdi          String?
  sgkIsyeriKodu            String?
  sgkSistemSifresi         String?
  sgkIsyeriSifresi         String?
  // TÜRMOB Entegratör
  turmobKullaniciAdi       String?
  turmobSifre              String?
  // e-Devlet Kapısı
  edevletTckn              String?
  edevletSifre             String?
  // İŞKUR İşveren Sistemi
  iskurTckn                String?
  iskurSifre               String?
  status                   String                   @default("active")
  notes                    String?
  verilmeyecekBeyannameler String[]                 @default([])
  beyannameAyarlari        Json                     @default("{}")
  siraNo                   String?
  sozlesmeNo               String?
  sozlesmeTarihi           String?
  tenantId                 String                   @db.Uuid
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  announcement_logs        announcement_logs[]
  beyanname_takip          beyanname_takip[]
  customer_group_members   customer_group_members[]
  tenants                  tenants                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents                documents[]
  email_messages           email_messages[]
  reminders                reminders[]
  sgk_kontrol              sgk_kontrol[]
  kdv_kontrol              kdv_kontrol[]
  kdv2_kontrol             kdv2_kontrol[]
  kdv9015_kontrol          kdv9015_kontrol[]
  gecici_vergi_kontrol     gecici_vergi_kontrol[]
  takip_satirlar           takip_satirlar[]
  tasks                    tasks[]

  customer_branches        customer_branches[]

  // Finansal İşlemler ilişkileri
  cost_definitions         cost_definitions[]
  financial_transactions   financial_transactions[]
  checks                   checks[]

  // Sorgulama Arşivi
  query_archives           query_archives[]

  @@unique([tenantId, vknTckn])
  @@index([tenantId])
  @@index([tenantId, status])
}

model customer_branches {
  id               String    @id @default(uuid()) @db.Uuid
  branchName       String
  sgkKullaniciAdi  String?
  sgkIsyeriKodu    String?
  sgkSistemSifresi String?
  sgkIsyeriSifresi String?
  customerId       String    @db.Uuid
  tenantId         String    @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  customers        customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants          tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, branchName])
  @@index([customerId])
  @@index([tenantId])
}

model documents {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  originalName    String?
  type            String
  mimeType        String?
  size            Int              @default(0)
  isFolder        Boolean          @default(false)
  parentId        String?          @db.Uuid
  path            String?
  url             String?
  storage         String           @default("local")
  year            Int?
  month           Int?
  icon            String?
  color           String?
  vknTckn         String?
  beyannameTuru   String?
  fileCategory    String?
  fileIndex       Int?
  customerId      String?          @db.Uuid
  tenantId        String           @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bulk_send_logs  bulk_send_logs[]
  customers       customers?       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  documents       documents?       @relation("documentsTodocuments", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_documents documents[]      @relation("documentsTodocuments")
  tenants         tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([beyannameTuru])
  @@index([parentId])
  @@index([tenantId, customerId])
  @@index([tenantId])
  @@index([vknTckn])
}

model sgk_kontrol {
  id                  String    @id @default(uuid()) @db.Uuid
  customerId          String    @db.Uuid
  year                Int
  month               Int

  // Hizmet Listesi bilgileri (PDF'den parse)
  hizmetIsciSayisi    Int?
  hizmetOnayTarihi    DateTime?
  hizmetDocumentId    String?   // Birden fazla dosya varsa virgülle ayrılmış UUID'ler
  hizmetDosyaSayisi   Int?      @default(1) // Kaç dosyanın toplandığı

  // Tahakkuk bilgileri (PDF'den parse)
  tahakkukIsciSayisi  Int?
  tahakkukGunSayisi   Int?
  tahakkukNetTutar    Decimal?  @db.Decimal(15, 2)
  tahakkukKabulTarihi DateTime?
  tahakkukDocumentId  String?   // Birden fazla dosya varsa virgülle ayrılmış UUID'ler
  tahakkukDosyaSayisi Int?      @default(1) // Kaç dosyanın toplandığı

  // Durum
  status              String    @default("bekliyor") // bekliyor, gonderildi, eksik
  notes               String?

  tenantId            String    @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customers           customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants             tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([customerId, year, month])
  @@index([tenantId])
  @@index([tenantId, year, month])
  @@index([customerId])
}

model kdv_kontrol {
  id                  String    @id @default(uuid()) @db.Uuid
  customerId          String    @db.Uuid
  year                Int
  month               Int

  // PDF'den parse edilen KDV verileri
  kdvMatrah           Decimal?  @db.Decimal(15, 2)
  tahakkukEden        Decimal?  @db.Decimal(15, 2)
  mahsupEdilen        Decimal?  @db.Decimal(15, 2)
  odenecek            Decimal?  @db.Decimal(15, 2)
  devredenKdv         Decimal?  @db.Decimal(15, 2)
  damgaVergisi        Decimal?  @db.Decimal(15, 2)
  vade                DateTime?
  beyanTarihi         DateTime?

  // Dosya referansları
  tahakkukDocumentId  String?
  tahakkukDosyaSayisi Int?      @default(1)

  // Durum
  status              String    @default("bekliyor")
  notes               String?

  tenantId            String    @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customers           customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants             tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([customerId, year, month])
  @@index([tenantId])
  @@index([tenantId, year, month])
  @@index([customerId])
}

