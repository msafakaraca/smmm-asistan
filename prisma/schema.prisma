model mails {
  id           String   @id @default(uuid()) @db.Uuid
  no           String
  isim         String
  unvan        String?
  email        String?
  telefon      String?
  mailSent     Boolean  @default(false)
  whatsappSent Boolean  @default(false)
  tenantId     String   @db.Uuid
  updatedAt    DateTime @updatedAt
  tenants      tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model passwords {
  id             String   @id @default(uuid()) @db.Uuid
  customerNo     String
  customerName   String
  emuhurSafeWord String?
  emuhurPin      String?
  gibUsername    String?
  gibPassword    String?
  otherPasswords Json?
  notes          String?
  tenantId       String   @db.Uuid
  updatedAt      DateTime @updatedAt
  tenants        tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reminders {
  id             String         @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  type           String         @default("event")
  date           DateTime?
  isAllDay       Boolean        @default(false)
  startTime      String?
  endTime        String?
  repeatPattern  String?
  repeatDays     String[]       @default([])
  repeatEndDate  DateTime?
  phoneNumber    String?
  sendWhatsApp   Boolean        @default(false)
  whatsappSentAt DateTime?
  status         String         @default("active")
  location       String?
  userId         String?        @db.Uuid
  tenantId       String         @db.Uuid
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customerId     String?        @db.Uuid
  customerIds    String[]       @default([]) @db.Uuid
  completed      Boolean        @default(false)
  dueDate        DateTime?
  customers      customers?     @relation(fields: [customerId], references: [id])
  tenants        tenants        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user_profiles  user_profiles? @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([tenantId, date])
  @@index([tenantId])
  @@index([userId])
}

model rows {
  id        String   @id @default(uuid()) @db.Uuid
  no        String
  isim      String
  platform  String?
  alis      Boolean?
  satis     Boolean?
  fis       Boolean?
  zRaporu   Boolean?
  muhtasar  String?
  vergiTA   Boolean?
  puantaj   Boolean?
  rapor     Boolean?
  sonDurum  Boolean  @default(false)
  notlar    String?
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model scheduled_announcements {
  id                     String                  @id @default(uuid()) @db.Uuid
  name                   String
  subject                String?
  content                String
  sendEmail              Boolean                 @default(false)
  sendSms                Boolean                 @default(false)
  sendWhatsApp           Boolean                 @default(false)
  scheduledAt            DateTime
  repeatPattern          String?
  repeatDay              Int?
  repeatEndDate          DateTime?
  lastExecutedAt         DateTime?
  nextExecuteAt          DateTime?
  targetType             String                  @default("selected")
  customerIds            String[]                @default([])
  groupIds               String[]                @default([])
  status                 String                  @default("active")
  templateId             String?                 @db.Uuid
  tenantId               String                  @db.Uuid
  createdBy              String                  @db.Uuid
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  announcement_logs      announcement_logs[]
  announcement_templates announcement_templates? @relation(fields: [templateId], references: [id])
  tenants                tenants                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([status])
  @@index([status, nextExecuteAt])
  @@index([tenantId])
}


model takip_kolonlar {
  id        String   @id @default(uuid()) @db.Uuid
  kod       String
  baslik    String
  tip       String   @default("boolean")
  siraNo    Int      @default(0)
  sistem    Boolean  @default(false)
  aktif     Boolean  @default(true)
  name      String?
  type      String?
  width     Int      @default(100)
  order     Int      @default(0)
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kod])
  @@index([aktif])
  @@index([siraNo])
  @@index([tenantId])
}

model takip_satirlar {
  id         String     @id @default(uuid()) @db.Uuid
  no         String?
  isim       String?
  customerId String?    @db.Uuid
  year       Int
  month      Int
  siraNo     Int        @default(0)
  degerler   Json       @default("{}")
  values     Json       @default("{}")
  tenantId   String     @db.Uuid
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  customers  customers? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants    tenants    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, year, month])
  @@index([siraNo])
  @@index([tenantId])
  @@index([year, month])
}

model task_assignees {
  id            String        @id @default(uuid()) @db.Uuid
  taskId        String        @db.Uuid
  userId        String        @db.Uuid
  assignedAt    DateTime      @default(now())
  tasks         tasks         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user_profiles user_profiles @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model task_attachments {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String
  originalName String
  mimeType     String?
  size         Int      @default(0)
  url          String
  storage      String   @default("supabase")
  taskId       String   @db.Uuid
  uploadedById String   @db.Uuid
  createdAt    DateTime @default(now())
  tasks        tasks    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model task_comments {
  id            String        @id @default(uuid()) @db.Uuid
  content       String
  taskId        String        @db.Uuid
  userId        String        @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tasks         tasks         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user_profiles user_profiles @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model tasks {
  id               String             @id @default(uuid()) @db.Uuid
  title            String
  description      String?
  priority         String             @default("medium")
  status           String             @default("todo")
  dueDate          DateTime?
  createdById      String             @db.Uuid
  tenantId         String             @db.Uuid
  customerId       String?            @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  task_assignees   task_assignees[]
  task_attachments task_attachments[]
  task_comments    task_comments[]
  user_profiles    user_profiles      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  customers        customers?         @relation(fields: [customerId], references: [id])
  tenants          tenants            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([customerId])
  @@index([tenantId, dueDate])
  @@index([tenantId])
  @@index([tenantId, priority])
  @@index([tenantId, status])
}

model tenants {
  id                      String                    @id @default(uuid()) @db.Uuid
  name                    String
  slug                    String                    @unique
  plan                    String                    @default("trial")
  status                  String                    @default("active")
  expiresAt               DateTime?
  settings                Json?
  gibSettings             Json?
  turmobSettings          Json?
  edevletSettings         Json?
  captchaKey              String?

  // Ofis Bilgileri
  email                   String?
  telefon                 String?
  adres                   String?
  vergiDairesi            String?
  vknTckn                 String?
  smmmSicilNo             String?

  // Bildirim Ayarları
  notificationSettings    Json?
  whatsappApiKey          String?

  // Finansal İşlemler Varsayılan Ayarlar
  financialDefaults       Json? // { hasSMM, defaultKdvRate, defaultStopajRate, autoChargeEnabled, autoChargeDay }

  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  announcement_logs       announcement_logs[]
  announcement_templates  announcement_templates[]
  beyanname_takip         beyanname_takip[]
  beyanname_turleri       beyanname_turleri[]
  bulk_send_logs          bulk_send_logs[]
  customer_branches       customer_branches[]
  customer_group_members  customer_group_members[]
  customer_groups         customer_groups[]
  customers               customers[]
  documents               documents[]
  email_messages          email_messages[]
  email_oauth_connections email_oauth_connections[]
  jobs                    jobs[]
  kontrol                 kontrol[]
  licenses                licenses?
  mails                   mails[]
  passwords               passwords[]
  reminders               reminders[]
  rows                    rows[]
  scheduled_announcements scheduled_announcements[]
  sgk_kontrol             sgk_kontrol[]
  kdv_kontrol             kdv_kontrol[]
  kdv2_kontrol            kdv2_kontrol[]
  kdv9015_kontrol         kdv9015_kontrol[]
  gecici_vergi_kontrol    gecici_vergi_kontrol[]
  takip_kolonlar          takip_kolonlar[]
  takip_satirlar          takip_satirlar[]
  tasks                   tasks[]
  audit_logs              audit_logs[]
  user_profiles           user_profiles[]
  // Finansal İşlemler ilişkileri
  finance_categories      finance_categories[]
  cost_definitions        cost_definitions[]
  financial_transactions  financial_transactions[]
  checks                  checks[]
  expenses                expenses[]
  auto_charge_logs        auto_charge_logs[]
  recurring_expense_logs  recurring_expense_logs[]
  query_archives          query_archives[]
}

model user_profiles {
  id             String           @id @db.Uuid
  tenantId       String           @db.Uuid
  role           String           @default("user")
  phoneNumber    String?
  email          String           @unique
  name           String
  image              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  invitedAt          DateTime?
  invitedBy          String?          @db.Uuid
  lastLoginAt        DateTime?
  permissions        String[]         @default([])
  status             String           @default("active")
  kvkkConsentAt      DateTime?
  kvkkConsentVersion String?
  jobs           jobs[]
  reminders      reminders[]
  task_assignees task_assignees[]
  task_comments  task_comments[]
  tasks          tasks[]
  query_archives query_archives[]
  tenants        tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}


// ============================================
// AUDIT LOGGING
// ============================================
model audit_logs {
  id         String   @id @default(uuid()) @db.Uuid
  timestamp  DateTime @default(now())

  // Kim yaptı?
  userId     String?  @db.Uuid
  userEmail  String?

  // Hangi tenant?
  tenantId   String   @db.Uuid

  // Ne yaptı?
  action     String   // LOGIN, LOGOUT, LOGIN_FAILED, CREATE, UPDATE, DELETE, VIEW, VIEW_SENSITIVE, EXPORT, IMPORT, BOT_START, BOT_COMPLETE, BOT_ERROR

  // Neyi etkiledi?
  resource   String   // customers, documents, beyanname_takip, credentials, etc.
  resourceId String?  @db.Uuid

  // Detaylar
  details    Json?    // Ek bilgiler (eski değer, yeni değer, hata mesajı, vb.)

  // İstek bilgileri
  ipAddress  String?
  userAgent  String?

  // İlişkiler
  tenants    tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, timestamp])
  @@index([tenantId, action])
  @@index([tenantId, resource])
  @@index([userId])
  @@index([timestamp])
}

// ============================================
// FİNANSAL İŞLEMLER - ENUM TANIMLARI
// ============================================

enum Currency {
  TRY
  USD
  EUR
}

enum Frequency {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
  ONE_TIME
}

enum ChargeStrategy {
  FULL
  DISTRIBUTED
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  EFT
  CHECK
  CREDIT_CARD
}

enum CheckStatus {
  IN_PORTFOLIO
  COLLECTED
  BOUNCED
  RETURNED
}

enum FinanceCategoryType {
  INCOME
  EXPENSE
}

enum AutoChargeStatus {
  SUCCESS
  FAILED
}

enum RecurringFrequency {
  REC_MONTHLY
  REC_QUARTERLY
  REC_ANNUAL
}

// ============================================
// FİNANSAL İŞLEMLER - MODELLERİ
// ============================================

model finance_categories {
  id        String              @id @default(uuid()) @db.Uuid
  name      String
  type      FinanceCategoryType
  isDefault Boolean             @default(false)
  color     String?
  icon      String?
  tenantId  String              @db.Uuid

  cost_definitions       cost_definitions[]
  financial_transactions financial_transactions[]
  expenses               expenses[]

  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name, type])
  @@index([tenantId])
}

model cost_definitions {
  id              String         @id @default(uuid()) @db.Uuid
  customerId      String         @db.Uuid
  categoryId      String         @db.Uuid
  description     String?
  amount          Decimal        @db.Decimal(12, 2)
  currency        Currency       @default(TRY)
  frequency       Frequency
  chargeStrategy  ChargeStrategy @default(FULL)
  hasSMM          Boolean        @default(true)
  kdvRate         Decimal?       @db.Decimal(5, 2)
  stopajRate      Decimal?       @db.Decimal(5, 2)
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean        @default(true)
  tenantId        String         @db.Uuid

  customers       customers          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category        finance_categories @relation(fields: [categoryId], references: [id])
  transactions    financial_transactions[]
  auto_charge_logs auto_charge_logs[]

  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, customerId])
  @@index([tenantId, isActive])
}

model financial_transactions {
  id                  String            @id @default(uuid()) @db.Uuid
  customerId          String?           @db.Uuid
  costDefinitionId    String?           @db.Uuid
  categoryId          String            @db.Uuid
  type                TransactionType
  amount              Decimal           @db.Decimal(12, 2)
  currency            Currency          @default(TRY)
  exchangeRate        Decimal?          @db.Decimal(10, 4)
  originalAmount      Decimal?          @db.Decimal(12, 2)
  grossAmount         Decimal?          @db.Decimal(12, 2)
  kdvAmount           Decimal?          @db.Decimal(12, 2)
  stopajAmount        Decimal?          @db.Decimal(12, 2)
  netAmount           Decimal           @db.Decimal(12, 2)
  description         String?
  date                DateTime
  dueDate             DateTime?
  paymentMethod       PaymentMethod?
  checkId             String?           @db.Uuid
  status              TransactionStatus @default(PENDING)
  parentTransactionId String?           @db.Uuid
  autoGenerated       Boolean           @default(false)
  tenantId            String            @db.Uuid

  customers          customers?              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  cost_definition    cost_definitions?       @relation(fields: [costDefinitionId], references: [id])
  category           finance_categories      @relation(fields: [categoryId], references: [id])
  check              checks?                 @relation(fields: [checkId], references: [id])
  parent_transaction financial_transactions? @relation("PartialPayments", fields: [parentTransactionId], references: [id])
  child_transactions financial_transactions[] @relation("PartialPayments")

  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, customerId, date])
  @@index([tenantId, status])
  @@index([tenantId, type, date])
  @@index([tenantId, categoryId])
}

model checks {
  id          String      @id @default(uuid()) @db.Uuid
  checkNumber String?
  bankName    String?
  amount      Decimal     @db.Decimal(12, 2)
  currency    Currency    @default(TRY)
  issueDate   DateTime
  dueDate     DateTime
  status      CheckStatus @default(IN_PORTFOLIO)
  customerId  String      @db.Uuid
  note        String?
  tenantId    String      @db.Uuid

  customers    customers              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions financial_transactions[]

  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, dueDate])
  @@index([tenantId, status])
}

model expenses {
  id                  String              @id @default(uuid()) @db.Uuid
  categoryId          String              @db.Uuid
  amount              Decimal             @db.Decimal(12, 2)
  currency            Currency            @default(TRY)
  date                DateTime
  description         String?
  isRecurring         Boolean             @default(false)
  recurringFrequency  RecurringFrequency?
  tenantId            String              @db.Uuid

  category finance_categories @relation(fields: [categoryId], references: [id])

  // Tekrarlayan gider log ilişkileri
  recurring_source_logs  recurring_expense_logs[] @relation("recurring_source")
  recurring_created_logs recurring_expense_logs[] @relation("recurring_created")

  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, categoryId])
}

model auto_charge_logs {
  id               String           @id @default(uuid()) @db.Uuid
  costDefinitionId String           @db.Uuid
  transactionId    String?          @db.Uuid
  period           String           // "2026-02" formatında
  status           AutoChargeStatus
  errorMessage     String?
  executedAt       DateTime         @default(now())
  tenantId         String           @db.Uuid

  cost_definition cost_definitions @relation(fields: [costDefinitionId], references: [id], onDelete: Cascade)

  tenants tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([costDefinitionId, period])
  @@index([tenantId])
}

model recurring_expense_logs {
  id               String           @id @default(uuid()) @db.Uuid
  sourceExpenseId  String           @db.Uuid
  createdExpenseId String?          @db.Uuid
  period           String           // "2026-02" formatında
  status           AutoChargeStatus // SUCCESS veya FAILED
  errorMessage     String?
  executedAt       DateTime         @default(now())
  tenantId         String           @db.Uuid

  source_expense  expenses  @relation("recurring_source", fields: [sourceExpenseId], references: [id], onDelete: Cascade)
  created_expense expenses? @relation("recurring_created", fields: [createdExpenseId], references: [id], onDelete: SetNull)
  tenants         tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([sourceExpenseId, period])
  @@index([tenantId])
}

// ============================================
// SORGULAMA ARŞİVİ
// ============================================
model query_archives {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @db.Uuid
  tenantId      String   @db.Uuid
  userId        String   @db.Uuid
  queryType     String   // "beyanname"|"tahsilat"|"edefter"|"earsiv"|"pos"|"okc"|"etebligat"

  month         Int      // 1-12
  year          Int      // 2025, 2026, ...

  resultData    Json     // Merge edilmiş tüm sonuçlar
  resultMeta    Json?    // { totalCount, ... }
  queryHistory  Json     @default("[]") // Array<{ date, params, addedCount }>
  totalCount    Int      @default(0)
  totalAmount   Decimal? @db.Decimal(15, 2)

  lastQueriedAt DateTime @default(now())
  queryCount    Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers     customers     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenants       tenants       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user_profiles user_profiles @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, queryType, month, year])
  @@index([tenantId, queryType])
  @@index([tenantId, customerId])
  @@index([tenantId, year, month])
}
