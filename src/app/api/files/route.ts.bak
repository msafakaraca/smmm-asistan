import { NextRequest, NextResponse } from "next/server";
import { auth } from "@/lib/auth";
import { getFile } from "@/lib/storage";

export async function GET(req: NextRequest) {
    const session = await auth();
    if (!session?.user) {
        return new NextResponse("Unauthorized", { status: 401 });
    }

    const { searchParams } = new URL(req.url);
    const filePath = searchParams.get("path");

    if (!filePath) {
        return new NextResponse("File path required", { status: 400 });
    }

    // Security: Ensure the path belongs to the logged-in user's tenant
    const tenantId = (session.user as any).tenantId;

    // Path format: storage/{tenantId}/...
    if (!filePath.startsWith(`storage/${tenantId}/`)) {
        return new NextResponse("Forbidden", { status: 403 });
    }

    try {
        const fileBuffer = await getFile(filePath);

        if (!fileBuffer) {
            return new NextResponse("File not found", { status: 404 });
        }

        return new NextResponse(new Uint8Array(fileBuffer), {
            headers: {
                "Content-Type": "application/pdf",
                "Content-Disposition": "inline", // Open in browser
            },
        });
    } catch (error) {
        console.error("File serve error:", error);
        return new NextResponse("Internal Server Error", { status: 500 });
    }
}
