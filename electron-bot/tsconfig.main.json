{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "outDir": "dist/main",
        "rootDir": "src/main",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true
    },
    "include": [
        "src/main/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}